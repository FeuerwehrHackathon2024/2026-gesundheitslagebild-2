# --- Flask ---
SECRET_KEY=change-me-to-a-long-random-string

# --- Web-Container ---
# Host-Port auf dem die App erreichbar ist (default 80)
WEB_PORT=80

# --- Postgres ---
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=hackathon

# --- App DB-Connection ---
# Wird von docker-compose.yml automatisch aus den POSTGRES_* Variablen gesetzt.
# Für lokale Entwicklung ohne Docker: auskommentieren → SQLite fallback aktiv.
# DATABASE_URL=postgresql+psycopg://hackathon:change-me-strong@db:5432/hackathon

# --- HERE Maps Routing API ---
# Wenn leer: App fällt auf Haversine-Schätzung zurück.
# Key anlegen unter: https://developer.here.com
HERE_API_KEY=
